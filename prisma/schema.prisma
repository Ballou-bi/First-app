generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model emploies {
  id      Int    @id @default(autoincrement())
  userId  String
  nom     String
  prenoms String
  email   String
  poste   String

  @@unique([userId, email])
}